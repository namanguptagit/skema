# ─── Rust ────────────────────────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock          # libraries should not lock; keep this if it's a binary

# ─── WebAssembly build output ─────────────────────────────────────────────────
# We commit the compiled WASM package so Vercel doesn't have to compile Rust
# web/src/core_pkg/

# ─── Node / Frontend ─────────────────────────────────────────────────────────
node_modules/
web/node_modules/
web/dist/
dist/

# ─── Vite / build caches ─────────────────────────────────────────────────────
web/.vite/
.vite/

# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── OS & editor artifacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
